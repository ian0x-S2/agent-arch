export const ConfirmScreen = ({
  selections,
  onConfirm,
  onBack,
}: {
  selections: Partial<UserSelections>;
  onConfirm: () => void;
  onBack: () => void;
}) => {
  useInput((input, key) => {
    if (key.return) onConfirm();

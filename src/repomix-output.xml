        <SelectInput
          items={inkItems}
          onSelect={(item) => onSelect(item.value)}
          onHighlight={(item) => setFocused(item.value)}
        />
      </Box>
      <OptionDescription option={focusedOption} />
      <Box marginTop={1}>
        <Text dimColor>Use ↑↓ to navigate, Enter to select</Text>
      </Box>
    </Box>
